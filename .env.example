# =============================================================================
# Vaccination Reminder Frontend — Environment Variables
# Copy to .env and fill in values. Do NOT commit .env (see .gitignore).
# Backend setup: ../cursor-challenge-backend/docs/ENVIRONMENT.md
# Connection guide: ../CONNECTION.md
# =============================================================================

# --- Supabase (phone auth — same project as backend) ---
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
# Anon public key — required for real phone OTP when VITE_USE_MOCK_AUTH=false
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Backend API ---
# Relative path; Vite dev proxy forwards /api → VITE_BACKEND_URL (see vite.config.ts)
VITE_API_BASE_URL=/api/v1
# Direct backend origin (dev default: http://localhost:3000)
VITE_BACKEND_URL=http://localhost:3000

# --- WebSocket (live hospital create/update events) ---
# Default in dev: ws://localhost:3000/ws/hospitals
# If unset, derived from VITE_BACKEND_URL (http→ws, https→wss) + /ws/hospitals
VITE_WS_URL=ws://localhost:3000/ws/hospitals

# --- Development mock auth (parent-side local setup) ---
# Use demo email/password login while Supabase anon key is a placeholder.
# Auto-enabled when VITE_SUPABASE_ANON_KEY contains YOUR_ or "placeholder".
VITE_USE_MOCK_AUTH=true

# Required when VITE_USE_MOCK_AUTH=true — must match backend SUPABASE_JWT_SECRET
VITE_DEV_JWT_SECRET=your-supabase-jwt-secret

# --- Firebase Cloud Messaging (Web Push) ---
# Create a Web app in Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# =============================================================================
# Parent-side quick start (mock auth + backend)
# =============================================================================
# 1. Start backend:  cd ../cursor-challenge-backend && npm run dev
# 2. Copy this file: cp .env.example .env
# 3. Set VITE_SUPABASE_URL to your Supabase project URL
# 4. Set VITE_DEV_JWT_SECRET to the same value as backend SUPABASE_JWT_SECRET
# 5. Keep VITE_USE_MOCK_AUTH=true until you have a real VITE_SUPABASE_ANON_KEY
# 6. Start frontend: npm run dev  →  http://localhost:5173
# 7. Sign in as parent with demo credentials (shown on login page):
#      email: parent@demo.com  password: password123
#    Phone +250788000001 is minted into a JWT and synced with GET /user/profile
# 8. Parent pages call the backend (no mock child/hospital data):
#      GET  /user/children, /user/children/:id/timeline
#      POST /user/children
#      PATCH /user/timeline/:itemId, /user/children/:id/preferred-hospital
#      GET  /user/hospitals/nearby
# 9. After adding a child, pick a preferred hospital on Nearby Hospitals to
#    generate the immunization timeline from that hospital's vaccine schedule.
