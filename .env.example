# =============================================================================
# Vaccination Reminder Frontend — Environment Variables
# Copy to .env and fill in values. Do NOT commit .env (see .gitignore).
# Backend setup: ../cursor-challenge-backend/docs/ENVIRONMENT.md
# =============================================================================

# --- Supabase (phone auth — same project as backend) ---
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Backend API ---
# Default: Vite dev proxy forwards /api → http://localhost:3000
# Uncomment to call backend directly (e.g. production):
# VITE_API_BASE_URL=https://your-api.example.com/api/v1

# --- Development fallback ---
# Use local demo email/password auth when Supabase is not configured:
# VITE_USE_MOCK_AUTH=true
#
# Required when VITE_USE_MOCK_AUTH=true — copy SUPABASE_JWT_SECRET from backend .env:
# VITE_DEV_JWT_SECRET=your-supabase-jwt-secret
